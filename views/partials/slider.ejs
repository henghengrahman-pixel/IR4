<% const activeSlides = (slides || []).filter(s => s && s.image); %>
<% if (activeSlides.length) { %>
<section class="container slider-wrap" id="slider-prediksi">
  <div class="slider" data-slider>
    <div class="slide-track" data-slider-track>
      <% activeSlides.forEach(function(slide) { %>
      <div class="slide">
        <a href="<%= slide.link || '#' %>" <%= (slide.link || '').startsWith('#') || (slide.link || '').startsWith('/') ? '' : 'target="_blank" rel="noopener"' %>>
          <img src="<%= slide.image %>" alt="<%= slide.title || 'Slide' %>" loading="lazy" onerror="this.closest('.slide').remove()">
          <% if (slide.title || slide.subtitle || slide.buttonText) { %><span class="slide-copy"><strong><%= slide.title || '' %></strong><small><%= slide.subtitle || '' %></small><em><%= slide.buttonText || '' %></em></span><% } %>
        </a>
      </div>
      <% }) %>
    </div>
    <% if (activeSlides.length > 1) { %><button class="ctrl prev" data-slider-prev aria-label="Sebelumnya">❮</button><button class="ctrl next" data-slider-next aria-label="Berikutnya">❯</button><div class="dots" data-slider-dots></div><% } %>
  </div>
</section>
<% } %>
