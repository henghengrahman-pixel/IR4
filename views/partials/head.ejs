<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1" />
<% const _title = pageTitle || settings.seoTitle || settings.metaTitle || settings.siteName || 'Portal Prediksi Bola'; %>
<% const _desc = pageDescription || settings.seoDescription || settings.metaDescription || ''; %>
<title><%= _title %></title>
<meta name="description" content="<%= _desc %>" />
<% if (settings.seoKeywords) { %><meta name="keywords" content="<%= settings.seoKeywords %>" /><% } %>
<% if (typeof canonical !== 'undefined' && canonical) { %><link rel="canonical" href="<%= canonical %>" /><% } %>
<meta property="og:title" content="<%= _title %>" />
<meta property="og:description" content="<%= _desc %>" />
<meta property="og:type" content="website" />
<% if (settings.faviconUrl) { %><link rel="icon" type="image/png" href="<%= settings.faviconUrl %>" /><% } %>
<% (styles || []).forEach(function(href) { %><link rel="stylesheet" href="<%= href %>" /><% }) %>
<% if (settings.backgroundDesktop || settings.backgroundMobile) { %>
<style>
  body{--site-bg-desktop:url('<%= settings.backgroundDesktop || settings.backgroundMobile %>');--site-bg-mobile:url('<%= settings.backgroundMobile || settings.backgroundDesktop %>')}
</style>
<% } %>
