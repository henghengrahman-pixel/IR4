<div class="admin-shell"><%- include('partials/sidebar') %><main class="admin-main"><h1>Kelola Slider Dinamis</h1>
<div class="admin-card"><h2>Tambah Slide</h2><form class="admin-form-grid" method="post" action="/admin/slides" enctype="multipart/form-data"><label>Title<input name="title" /></label><label>Subtitle<input name="subtitle" /></label><label>Image URL<input name="image" /></label><label>Upload Image<input type="file" name="imageFile" accept="image/*" /></label><label>Button Text<input name="buttonText" /></label><label>Button Link<input name="link" /></label><label>Order<input type="number" name="order" value="1" /></label><label class="checkbox"><input type="checkbox" name="active" checked /> Active</label><button class="admin-btn" type="submit">Tambah Slide</button></form></div>
<% slides.forEach(function(item){ %><div class="admin-card"><form class="admin-form-grid" method="post" action="/admin/slides/<%= item.id %>/update" enctype="multipart/form-data"><label>Title<input name="title" value="<%= item.title || '' %>" /></label><label>Subtitle<input name="subtitle" value="<%= item.subtitle || '' %>" /></label><label>Image URL<input name="image" value="<%= item.image || '' %>" /></label><label>Upload Image<input type="file" name="imageFile" accept="image/*" /></label><label>Button Text<input name="buttonText" value="<%= item.buttonText || '' %>" /></label><label>Button Link<input name="link" value="<%= item.link || '' %>" /></label><label>Order<input type="number" name="order" value="<%= item.order || 0 %>" /></label><label class="checkbox"><input type="checkbox" name="active" <%= item.active ? 'checked' : '' %> /> Active</label><button class="admin-btn" type="submit">Update</button></form><form method="post" action="/admin/slides/<%= item.id %>/delete" onsubmit="return confirm('Hapus slide ini?')"><button class="admin-btn danger" type="submit">Hapus</button></form><% if (item.image) { %><img src="<%= item.image %>" style="max-width:260px;border-radius:12px;margin-top:12px" onerror="this.remove()"><% } %></div><% }) %>
</main></div>
