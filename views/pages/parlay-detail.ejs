<%- include('../partials/topbar') %>
<%- include('../partials/ticker') %>
<%- include('../partials/slider') %>
<%- include('../partials/auth-buttons') %>

<section class="parlay-page with-home-bg">
  <main class="container parlay-layout parlay-single-layout">
    <article class="parlay-single">
      <div class="single-top">
        <a class="badge" href="/category/<%= String(post.category || '').toLowerCase().replace(/[^a-z0-9]+/g,'-').replace(/^-|-$/g,'') %>"><%= post.category || 'Prediksi Parlay' %></a>
        <div class="single-live">🔥 UPDATE TERBARU</div>
      </div>

      <h1><%= post.title %></h1>

      <div class="single-meta">
        <span>👑 By <strong><%= post.author || 'Master Parlay' %></strong></span>
        <span>🕒 <%= fmtDate(post.createdAt) %></span>
        <span>⚽ Analisa AI</span>
        <% (post.tags || []).forEach(function(tag){ %><span>#<%= tag %></span><% }) %>
      </div>

      <% if (post.thumbnail) { %>
        <div class="single-image-wrap">
          <img class="single-cover" src="<%= post.thumbnail %>" alt="<%= post.title %>">
          <div class="single-image-overlay"><span>🔥 HOT PARLAY</span></div>
        </div>
      <% } %>

      <div class="article-content"><%- post.content %></div>

      <% if ((post.predictions || []).length) { %>
        <div class="prediction-header">
          <span>⚽ ANALISA MATCH</span>
          <h2>SARAN PREDIKSI PARLAY MALAM INI</h2>
          <p>Prediksi berdasarkan jadwal pertandingan aktif, liga besar, Liga Indonesia, dan analisa otomatis.</p>
        </div>

        <% post.predictions.forEach(function(league){ %>
          <div class="league-box">
            <div class="league-head">
              <div class="league-icon">⚽</div>
              <h2 class="league-title"><%= league.league %></h2>
            </div>
            <div class="table-wrap">
              <table class="prediksi-table">
                <thead>
                  <tr><th>MATCH</th><th>1X2</th><th>O/U</th><th>SKOR</th><th>DETAIL</th></tr>
                </thead>
                <tbody>
                  <% league.matches.forEach(function(rawMatch){ const match = normalizeMatchItem(rawMatch, league.league, post); %>
                    <tr class="<%= match.hotMatch ? 'hot-row' : '' %>">
                      <td>
                        <a class="match-link" href="<%= matchUrl(match) %>">
                          <strong><%= match.match %></strong>
                          <% if (match.hotMatch) { %><span class="hot-mini">🔥 HOT</span><% } %>
                        </a>
                      </td>
                      <td><span class="pick-badge"><%= match.pick %></span></td>
                      <td><span class="ou-badge"><%= match.ou %></span></td>
                      <td><span class="score-badge"><%= match.score %></span></td>
                      <td><a class="detail-btn" href="<%= matchUrl(match) %>">Lihat</a></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        <% }) %>
      <% } %>

      <div class="parlay-note">
        <div class="note-box">
          <div class="note-icon">⚠️</div>
          <div class="note-content">
            <h3>Rekomendasi Bermain Aman</h3>
            <p>Gunakan prediksi ini sebagai referensi tambahan. Selalu bermain secara bijak dan kelola risiko dengan batas yang aman.</p>
          </div>
        </div>
      </div>

      <% if (related.length) { %>
        <div class="related">
          <div class="related-head">🔥 Related Prediction</div>
          <div class="related-grid">
            <% related.forEach(function(item){ %>
              <a href="<%= parlayUrl(item) %>" class="related-card">
                <div class="related-thumb"><img src="<%= item.thumbnail %>" alt="<%= item.title %>"></div>
                <div class="related-body"><span class="badge">PARLAY</span><h4><%= item.title %></h4></div>
              </a>
            <% }) %>
          </div>
        </div>
      <% } %>
    </article>
    <%- include('../partials/sidebar-blog', { latestPosts, ads }) %>
  </main>
</section>

<%- include('../partials/footer') %>
<%- include('../partials/quick-menu') %>
