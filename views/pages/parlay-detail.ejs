<%- include('../partials/topbar') %>
<%- include('../partials/ticker') %>
<%- include('../partials/slider') %>
<%- include('../partials/auth-buttons') %>

<main class="container single-clean-layout">

  <article class="single-clean-card">

    <div class="single-top">

      <a
        class="single-badge"
        href="/category/<%= String(post.category || '').toLowerCase().replace(/[^a-z0-9]+/g,'-').replace(/^-|-$/g,'') %>"
      >
        ⚽ <%= post.category || 'Prediksi Parlay' %>
      </a>

      <h1>
        <%= post.title %>
      </h1>

      <div class="single-meta-clean">

        <span>
          🕒 <%= fmtDate(post.createdAt) %>
        </span>

        <span>
          👤 <%= post.author || 'Master Parlay' %>
        </span>

      </div>

    </div>

    <% if (post.thumbnail) { %>

      <div class="single-cover-wrap">

        <img
          class="single-cover-clean"
          src="<%= post.thumbnail %>"
          alt="<%= post.title %>"
        >

      </div>

    <% } %>

    <% const st = post.parlayStats || {}; %>

    <section class="top-stats-clean">

      <div class="stat-clean">

        <small>Win Rate</small>

        <strong>
          <%= st.winRate || 90 %>%
        </strong>

      </div>

      <div class="stat-clean">

        <small>Confidence</small>

        <strong>
          <%= st.avgConfidence || 88 %>%
        </strong>

      </div>

      <div class="stat-clean">

        <small>Odds Estimasi</small>

        <strong>
          <%= st.totalOdds || '5.32' %>
        </strong>

      </div>

    </section>

    <div class="article-content article-clean">

      <%- post.content %>

    </div>

    <% if ((post.predictions || []).length) { %>

      <section class="simple-prediction">

        <h2 class="simple-title">
          SARAN PREDIKSI PARLAY NANTI MALAM YANG LEBIH AKURAT
        </h2>

        <div class="simple-subtitle">
          PREDIKSI PARLAY MALAM INI
        </div>

        <% post.predictions.forEach(function(league){ %>

          <div class="league-block">

            <h3 class="league-name-simple">
              <%= league.league %>
            </h3>

            <table class="prediksi-table-clean">

              <thead>

                <tr>

                  <th>Match</th>

                  <th>1X2</th>

                  <th>O/U</th>

                  <th>Skor</th>

                </tr>

              </thead>

              <tbody>

                <% league.matches.forEach(function(match){ %>

                  <tr>

                    <td>
                      <%= match.match %>
                    </td>

                    <td>
                      <strong>
                        <%= match.pick %>
                      </strong>
                    </td>

                    <td>
                      <%= match.ou %>
                    </td>

                    <td>
                      <%= match.score %>
                    </td>

                  </tr>

                <% }) %>

              </tbody>

            </table>

          </div>

        <% }) %>

      </section>

    <% } %>

    <section class="note-clean">

      <strong>
        Catatan
      </strong>

      <p>
        Prediksi ini dibuat berdasarkan analisa pertandingan, statistik tim, performa terbaru, dan faktor pendukung lainnya. Gunakan prediksi secara bijak dan tetap atur manajemen permainan dengan baik.
      </p>

    </section>

    <% if (related.length) { %>

      <section class="related-clean">

        <h3>
          Prediksi Lainnya
        </h3>

        <div class="related-clean-grid">

          <% related.forEach(function(item){ %>

            <a href="<%= parlayUrl(item) %>">

              <%= item.title %>

            </a>

          <% }) %>

        </div>

      </section>

    <% } %>

  </article>

  <%- include('../partials/sidebar-blog', { latestPosts, ads }) %>

</main>

<%- include('../partials/footer') %>
<%- include('../partials/quick-menu') %>
