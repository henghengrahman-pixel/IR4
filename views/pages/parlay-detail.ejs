<%- include('../partials/topbar') %>
<%- include('../partials/ticker') %>
<%- include('../partials/slider') %>
<%- include('../partials/auth-buttons') %>
<main class="container parlay-layout parlay-single-layout">
  <article class="parlay-single parlay-single-pro">
    <a class="badge" href="/category/<%= String(post.category || '').toLowerCase().replace(/[^a-z0-9]+/g,'-').replace(/^-|-$/g,'') %>"><%= post.category || 'Prediksi Parlay' %></a>
    <h1><%= post.title %></h1>
    <div class="single-meta">By <strong><%= post.author || 'Master Parlay' %></strong> • <%= fmtDate(post.createdAt) %> • <% (post.tags || []).forEach(function(tag){ %><span>#<%= tag %></span> <% }) %></div>
    <% if (post.thumbnail) { %><img class="single-cover" src="<%= post.thumbnail %>" alt="<%= post.title %>"><% } %>
    <% const st = post.parlayStats || {}; %>
    <section class="single-stats-pro">
      <div><b><%= st.winRate || 90 %>%</b><span>Win Rate</span></div>
      <div><b><%= st.avgConfidence || 88 %>%</b><span>Confidence</span></div>
      <div><b><%= st.totalOdds || '5.32' %></b><span>Odds Estimasi</span></div>
      <div><b><%= st.safeCount || 3 %></b><span>Safe Pick</span></div>
    </section>
    <div class="article-content"><%- post.content %></div>
    <% if ((post.predictions || []).length) { %>
      <div class="prediction-heading-pro"><h2>Prediksi Parlay Pilihan</h2><p>Detail match lengkap dengan jam, liga, pick utama, odds estimasi, confidence, form, H2H, dan alasan singkat.</p></div>
      <% post.predictions.forEach(function(league){ %>
        <h2 class="league-title"><%= league.league %></h2>
        <div class="match-card-grid">
          <% league.matches.forEach(function(match){ %>
            <article class="match-pro-card">
              <div class="match-pro-head"><span><%= match.badge %></span><b><%= match.status %></b></div>
              <h3><%= match.match %></h3>
              <div class="match-sub"><span>⏱ <%= match.time %></span><span>🏆 <%= league.league %></span></div>
              <div class="pick-grid">
                <div><small>1X2</small><strong><%= match.pick %></strong></div>
                <div><small>O/U</small><strong><%= match.ou %></strong></div>
                <div><small>Skor</small><strong><%= match.score %></strong></div>
                <div><small>Odds</small><strong><%= match.odds %></strong></div>
              </div>
              <div class="confidence-block"><div class="confidence-label"><span>Confidence</span><b><%= match.confidence %>%</b></div><div class="confidence-bar"><i style="width:<%= match.confidence %>%"></i></div></div>
              <div class="mini-analysis-grid">
                <div><small>Win Rate</small><b><%= match.winRate %>%</b></div>
                <div><small>Risk</small><b><%= match.risk %></b></div>
                <div><small>Form Home</small><b><%= match.formHome %></b></div>
                <div><small>Form Away</small><b><%= match.formAway %></b></div>
                <div><small>H2H</small><b><%= match.h2h %></b></div>
                <div><small>Trend</small><b><%= match.trend %></b></div>
              </div>
              <p class="reason-line"><%= match.reason %></p>
            </article>
          <% }) %>
        </div>
      <% }) %>
    <% } %>
    <div class="parlay-builder-pro">
      <h3>Parlay Builder</h3>
      <p>Ambil 3–5 match dengan confidence tertinggi untuk kombinasi yang lebih aman. Hindari memasukkan terlalu banyak match dalam satu tiket.</p>
      <div class="builder-tags"><span>✅ Safe Pick</span><span>🔥 Big Match</span><span>💎 Best Pick</span><span>🎯 Odds Estimasi</span></div>
      <a href="<%= settings.registerUrl || '#' %>" class="builder-cta">Cek Odds Live</a>
    </div>
    <div class="parlay-note">
      <p><strong>Catatan Penting</strong></p>
      <p>Prediksi ini adalah referensi analisa pertandingan. Selalu gunakan manajemen risiko dan jangan mengejar kekalahan.</p>
    </div>
    <% if (related.length) { %><div class="related"><h3>Related Post</h3><div class="related-grid"><% related.forEach(function(item){ %><a href="<%= parlayUrl(item) %>"><%= item.title %></a><% }) %></div></div><% } %>
  </article>
  <%- include('../partials/sidebar-blog', { latestPosts, ads }) %>
</main>
<%- include('../partials/footer') %>
<%- include('../partials/quick-menu') %>
