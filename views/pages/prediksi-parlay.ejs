<%- include('../partials/topbar') %>
<%- include('../partials/ticker') %>
<%- include('../partials/slider') %>
<%- include('../partials/auth-buttons') %>

<section class="parlay-hero-clean">
  <div class="container hero-clean-wrap">

    <div class="hero-left">
      <span class="hero-label">
        🔥 Prediksi Bola Premium
      </span>

      <h1>
        Prediksi Parlay Hari Ini
      </h1>

      <p>
        Update prediksi pilihan dengan odds estimasi, confidence, dan analisa singkat yang lebih simple, rapi, dan mudah dibaca.
      </p>

      <div class="hero-btns">
        <a href="#parlay-list" class="btn-main">
          LIHAT PREDIKSI
        </a>

        <a href="<%= settings.registerUrl || '#' %>" class="btn-second">
          MAIN SEKARANG
        </a>
      </div>
    </div>

    <div class="hero-right">
      <div class="hero-box">
        <span>PARLAY HARI INI</span>

        <strong>
          <%= allPosts[0]?.parlayStats?.totalOdds || '5.32' %>
        </strong>

        <small>
          Odds Estimasi
        </small>
      </div>

      <div class="hero-box">
        <span>CONFIDENCE</span>

        <strong>
          <%= allPosts[0]?.parlayStats?.avgConfidence || 88 %>%
        </strong>

        <small>
          Win Rate Tinggi
        </small>
      </div>
    </div>

  </div>
</section>

<main class="container parlay-clean-layout" id="parlay-list">

  <div class="section-clean">
    <h2>Update Prediksi Terbaru</h2>
    <p>
      Prediksi pilihan dengan tampilan simple dan fokus ke match utama.
    </p>
  </div>

  <% if (!posts.length) { %>

    <div class="empty-clean">
      Belum ada prediksi yang dipublish.
    </div>

  <% } %>

  <div class="clean-grid">

    <% posts.forEach(function(post){ const st = post.parlayStats || {}; %>

      <article class="match-card-clean">

        <a href="<%= parlayUrl(post) %>" class="match-thumb">
          <img
            src="<%= post.thumbnail %>"
            alt="<%= post.title %>"
            loading="lazy"
          >
        </a>

        <div class="match-content">

          <div class="top-match">

            <span class="league-name">
              ⚽ <%= post.category || 'Prediksi Parlay' %>
            </span>

            <span class="live-badge">
              HOT
            </span>

          </div>

          <h3>
            <a href="<%= parlayUrl(post) %>">
              <%= post.title %>
            </a>
          </h3>

          <div class="match-meta">
            🕒 <%= fmtDate(post.createdAt) %>
          </div>

          <% if (st.bestPick) { %>

            <div class="pick-box">
              🎯 PICK :
              <strong>
                <%= st.bestPick.market %>
              </strong>
            </div>

          <% } %>

          <div class="odds-row">

            <div>
              <span>Odds</span>
              <strong>
                <%= st.totalOdds || '1.88' %>
              </strong>
            </div>

            <div>
              <span>Confidence</span>
              <strong>
                <%= st.avgConfidence || 88 %>%
              </strong>
            </div>

          </div>

          <div class="confidence-bar">
            <div
              class="confidence-fill"
              style="width:<%= st.avgConfidence || 88 %>%"
            ></div>
          </div>

          <p class="match-desc">
            <%= post.excerpt %>
          </p>

          <a
            href="<%= parlayUrl(post) %>"
            class="btn-prediction"
          >
            LIHAT ANALISA
          </a>

        </div>

      </article>

    <% }) %>

  </div>

  <div class="pagination">

    <% if (currentPage > 1) { %>
      <a href="/prediksi-parlay?page=<%= currentPage - 1 %>">
        ‹
      </a>
    <% } %>

    <% for(let i=1; i<=totalPages; i++){ %>

      <% if (
        i === currentPage ||
        i <= 2 ||
        i === totalPages ||
        Math.abs(i-currentPage)<=1
      ) { %>

        <a
          class="<%= i === currentPage ? 'on' : '' %>"
          href="/prediksi-parlay?page=<%= i %>"
        >
          <%= i %>
        </a>

      <% } else if (i === 3 && currentPage > 4) { %>

        <span>...</span>

      <% } %>

    <% } %>

    <% if (currentPage < totalPages) { %>
      <a href="/prediksi-parlay?page=<%= currentPage + 1 %>">
        ›
      </a>
    <% } %>

  </div>

</main>

<%- include('../partials/footer') %>
<%- include('../partials/quick-menu') %>
