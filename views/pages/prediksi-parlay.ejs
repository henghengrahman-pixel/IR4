<%- include('../partials/topbar') %>
<%- include('../partials/ticker') %>
<%- include('../partials/slider') %>
<%- include('../partials/auth-buttons') %>

<section class="parlay-page with-home-bg">
  <section class="parlay-hero">
    <div class="container">
      <div class="hero-box">
        <span class="hero-badge">🔥 PREDIKSI PARLAY TERUPDATE</span>
        <h1>PREDIKSI PARLAY JITU</h1>
        <p>Update prediksi parlay malam ini berdasarkan pertandingan aktif, liga besar, Liga Indonesia, dan analisa otomatis.</p>
        <div class="hero-stats">
          <div class="hero-stat"><strong><%= allPosts.length %>+</strong><span>Artikel Prediksi</span></div>
          <div class="hero-stat"><strong>LIVE</strong><span>Update Otomatis</span></div>
          <div class="hero-stat"><strong>AI</strong><span>Analisa Match</span></div>
        </div>
      </div>
    </div>
  </section>

  <main class="container parlay-layout">
    <section class="parlay-list">
      <% if (!posts.length) { %>
        <article class="parlay-empty"><div class="empty-icon">⚽</div><h3>Belum Ada Prediksi</h3><p>Prediksi parlay otomatis akan segera diperbarui.</p></article>
      <% } %>

      <% posts.forEach(function(post){
        const hotCount = (post.predictions || []).reduce((sum, league) => sum + (league.matches || []).filter(m => m.hotMatch).length, 0);
      %>
        <article class="parlay-card">
          <a class="parlay-thumb" href="<%= parlayUrl(post) %>">
            <img src="<%= post.thumbnail %>" alt="<%= post.title %>" loading="lazy">
            <div class="thumb-overlay"><span>🔥 HOT MATCH: <%= hotCount %></span></div>
          </a>
          <div class="parlay-body">
            <div class="post-top">
              <a class="badge" href="/category/<%= String(post.category || '').toLowerCase().replace(/[^a-z0-9]+/g,'-').replace(/^-|-$/g,'') %>"><%= post.category || 'Prediksi Parlay' %></a>
              <span class="date-mini">🕒 <%= fmtDate(post.createdAt) %></span>
            </div>
            <h2><a href="<%= parlayUrl(post) %>"><%= post.title %></a></h2>
            <div class="post-meta"><span>👑 <%= post.author || 'Master Parlay' %></span><span>⚽ Analisa Pertandingan</span><span>🔥 Auto Update</span></div>
            <p><%= post.excerpt %></p>
            <div class="post-actions"><a href="<%= parlayUrl(post) %>" class="read-btn">LIHAT PREDIKSI →</a></div>
          </div>
        </article>
      <% }) %>

      <div class="pagination">
        <% if (currentPage > 1) { %><a href="/prediksi-parlay?page=<%= currentPage - 1 %>">‹</a><% } %>
        <% for(let i=1; i<=totalPages; i++){ %>
          <% if (i === currentPage || i <= 2 || i === totalPages || Math.abs(i-currentPage)<=1) { %>
            <a class="<%= i === currentPage ? 'on' : '' %>" href="/prediksi-parlay?page=<%= i %>"><%= i %></a>
          <% } else if (i === 3 && currentPage > 4) { %><span>...</span><% } %>
        <% } %>
        <% if (currentPage < totalPages) { %><a href="/prediksi-parlay?page=<%= currentPage + 1 %>">›</a><% } %>
      </div>
    </section>
    <%- include('../partials/sidebar-blog', { latestPosts: allPosts.slice(0, 8), ads }) %>
  </main>
</section>

<%- include('../partials/footer') %>
<%- include('../partials/quick-menu') %>
