<%- include('../partials/topbar') %>
<%- include('../partials/ticker') %>
<%- include('../partials/slider') %>
<%- include('../partials/auth-buttons') %>

<section class="news-hero news-hero-premium">
  <div class="container">
    <span class="news-kicker">PORTAL BERITA BOLA</span>
    <h1>Berita Bola Terbaru</h1>
    <p>Update sepak bola terbaru, transfer pemain, big match, jadwal liga besar, hasil pertandingan, dan artikel pilihan.</p>
  </div>
</section>

<main class="container news-layout news-index-premium">
  <section class="news-list">
    <% if (!news.length) { %>
      <div class="news-empty">Belum ada berita. Silakan tambah artikel dari admin.</div>
    <% } %>

    <% news.forEach(function(item){ %>
      <article class="news-card">
        <a class="news-thumb" href="/berita/<%= item.slug %>">
          <% if (item.thumbnail) { %>
            <img src="<%= item.thumbnail %>" alt="<%= item.title %>" loading="lazy">
          <% } else { %>
            <span>BERITA BOLA</span>
          <% } %>
        </a>

        <div class="news-card-body">
          <div class="news-meta-top">
            <span class="news-badge"><%= item.category || 'Berita Bola' %></span>
            <% if ((item.tags||[]).length) { %><span><%= item.tags[0] %></span><% } %>
          </div>
          <h2><a href="/berita/<%= item.slug %>"><%= item.title %></a></h2>
          <div class="news-meta"><%= fmtDate(item.publishedAt || item.createdAt) %> • <%= item.author || 'Redaksi Bola' %></div>
          <p><%= item.excerpt || '' %></p>
          <a class="read-more" href="/berita/<%= item.slug %>">Baca Selengkapnya</a>
        </div>
      </article>
    <% }) %>
  </section>

  <aside class="news-sidebar">
    <div class="side-box">
      <h3><%= settings.newsSearchTitle || 'Cari Berita' %></h3>
      <form class="news-search" action="/berita" method="get">
        <input name="q" value="<%= q || '' %>" placeholder="Cari berita bola...">
        <button>Cari</button>
      </form>
    </div>

    <div class="side-box">
      <h3>Artikel Terbaru</h3>
      <div class="trend-list">
        <% trending.forEach(function(item){ %>
          <a class="trend-item" href="/berita/<%= item.slug %>">
            <% if(item.thumbnail){ %>
              <img src="<%= item.thumbnail %>" alt="<%= item.title %>">
            <% } else { %>
              <span class="trend-ph">⚽</span>
            <% } %>
            <div>
              <strong><%= item.title %></strong>
              <small><%= fmtDate(item.publishedAt || item.createdAt) %></small>
            </div>
          </a>
        <% }) %>
      </div>
    </div>

    <div class="side-box">
      <h3><%= settings.newsCategoryTitle || 'Kategori Populer' %></h3>
      <div class="cat-list">
        <% categories.forEach(function(c){ %>
          <a href="/berita?category=<%= encodeURIComponent(c) %>"><%= c %></a>
        <% }) %>
      </div>
    </div>

    <% if (settings.sidebarBanner) { %>
      <a class="side-banner" href="#"><img src="<%= settings.sidebarBanner %>" alt="Banner"></a>
    <% } %>
  </aside>
</main>

<%- include('../partials/footer') %>
<%- include('../partials/quick-menu') %>
